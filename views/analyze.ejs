<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Analyze Sucrose Data</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
body {
    position: relative;
    z-index: 1;
}

/* Transparent background image layer */
body::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    
    background: url('/images/sugar.jpeg') center/cover no-repeat fixed;

    opacity: 0.3; /* <-- TRANSPARENCY WORKS HERE */
    z-index: -1;  /* keep behind everything */
}



        h1 {
            text-align: center;
            margin-bottom: 30px;
            color: #333;
        }

        form {
            display: flex;
            justify-content: center;
            margin-bottom: 30px;
            gap: 10px;
        }

        form input, form button {
            padding: 8px 12px;
            font-size: 16px;
            border-radius: 5px;
            border: 1px solid #ccc;
        }

        form button {
            background-color: #4CAF50;
            color: white;
            border: none;
            cursor: pointer;
        }

        form button:hover {
            background-color: #45a049;
        }

        .chart-row {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
            margin-bottom: 30px;
        }

        .chart-container {
            flex: 1 1 400px; /* flexible width, minimum 400px */
            max-width: 600px;
            background-color: #fff;
            padding: 15px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        canvas {
            width: 100% !important;
            height: 300px !important;
        }
    </style>
</head>
<body>









<center><h1>Analyze Sucrose Data</h1>

<form action="/analyze" method="POST">
    <input type="date" name="date" required>
    <button type="submit">Analyze</button>
</form>
<button onclick="window.location.href='/homepage'" 
        style=" padding: 8px 12px; font-size:16px; border-radius:5px; border:1px solid #ccc; background-color:#45a049; color:white; cursor:pointer;">
    Go to Home
</button></center>

<% if (data && data.length > 0) { %>

    <!-- Two charts side by side -->
    <div class="chart-row">
        <div class="chart-container">
            <canvas id="brixTempChart"></canvas>
        </div>
        <div class="chart-container">
            <canvas id="correctedBrixRecoveryChart"></canvas>
        </div>
    </div>

    <!-- One chart below -->
    <div class="chart-row">
        <div class="chart-container">
            <canvas id="correctedPolRecoveryChart"></canvas>
        </div>
    </div>

    <!-- Pass data safely to JS -->
    <script id="data-json" type="application/json">
        <%- JSON.stringify(data) %>
    </script>

    <!-- Include analyze.js -->
    <script src="/js/analyze.js"></script>

<% } else if (data) { %>
    <p style="text-align:center; font-size:18px; color:#555;">No data available for the selected date.</p>
<% } %>

</body>
</html>
